# IDE
.idea/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/

# oropt run artefacts (decks, restarts, animations, status, checkpoints)
runs/

# demo-backend benchmark / sweep harness output (scripts/benchmark_optimizers.py, sweep.py)
benchmark_out/
sweep_out/

# OpenRadioss outputs that may land next to a deck
*.rst
*A0[0-9][0-9]
*T0[0-9]
*_0000.out
*_0001.out
*.h3d

# LS-PrePost session artefacts (land next to decks when viewing the d3plot)
lspost.cfile
lspost.msg

# GUI run-queue state (disk-backed serial queue + its lock)
run_queue.json
run_queue.json.*
# Immutable per-run config snapshots the queue launches from
queue_configs/

# scratch
_probe.*
_pdf_text.txt
_st*.log
_h.txt
